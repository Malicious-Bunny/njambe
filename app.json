{
  "expo": {
    "name": "njambe",
    "slug": "njambe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "njambe",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.njambe.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Njambe uses your location to set the service address and find providers near you.",
        "NSPhotoLibraryUsageDescription": "Njambe needs access to your photo library to attach photos to your service request."
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "ADD_YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Njambe to access your location to set the service address."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Njambe to access your photo library to attach photos to your service request."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
